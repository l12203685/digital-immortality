# Example environment variables for digital-immortality scripts.
# Copy to a private location (e.g. ~/.claude/credentials/.env) and fill in real
# values. NEVER commit the filled version. The tracked `.env` pattern in
# .gitignore prevents accidental commits.
#
# See ~/.claude/credentials/README.md for the full registry and rotation policy.

# --- Anthropic / LLM ---------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Google Sheets (finance dashboard) ---------------------------------------
EDWARD_FINANCE_SHEET_ID=
GOOGLE_SHEETS_CREDENTIALS_PATH=

# --- Google Calendar ---------------------------------------------------------
GOOGLE_CALENDAR_CLIENT_SECRET_PATH=
GOOGLE_CALENDAR_TOKEN_PATH=

# --- Binance (trading engine) ------------------------------------------------
BINANCE_CREDENTIALS_PATH=

# --- Discord webhooks --------------------------------------------------------
# #永生樹 — used by recursive_daemon, trading/engine, escalation_batcher
DISCORD_WEBHOOK_TREE=
# DOS organism-edward #thinking — used by recursive_daemon
DISCORD_WEBHOOK_DOS=
# Edward personal webhook — used by arena_bot (fallback when DISCORD_WEBHOOK_URL unset)
DISCORD_WEBHOOK_EDWARD=
# Generic override consumed by arena_bot.load_webhook_url
DISCORD_WEBHOOK_URL=

# --- Intake server -----------------------------------------------------------
# Optional auth token for platform/intake_server.py. Leave blank to disable.
INTAKE_API_KEY=
